{
  "name": "markzen",
  "productName": "Markzen",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Markdown editor/viewer",
  "private": true,
  "author": "yaiol",
  "main": "electron/main.mjs",
  "homepage": "./",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaiol/markzen.git"
  },
  "devPort": 3003,
  "storagePrefix": "mzn",
  "cliName": "markzen-cli",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm start\" \"wait-on http://localhost:3003 && electron .\"",
    "postinstall": "node scripts/patch-pseudocode.js",
    "ci:prepare": "node scripts/fetch-pandoc.mjs",
    "dist": "npm run ci:prepare && npm run build && electron-builder --win --x64",
    "dist:mac": "npm run ci:prepare && npm run build && electron-builder --mac",
    "dist:linux": "npm run ci:prepare && npm run build && electron-builder --linux",
    "check:extensions": "node scripts/check-extensions.js"
  },
  "dependencies": {
    "brace-expansion": "^5.0.5",
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "handlebars": "^4.7.9",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.4",
    "wtf_wikipedia": "^10.4.2",
    "wtf-plugin-html": "^1.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@dbml/core": "^8.3.0",
    "@djot/djot": "^0.3.2",
    "@hpcc-js/wasm": "^2.34.2",
    "@hpcc-js/wasm-graphviz": "^1.22.2",
    "@vitejs/plugin-react": "^6.0.3",
    "abcjs": "^6.6.3",
    "asciidoctor": "^4.0.0",
    "asciimath2tex": "^1.5.0",
    "chart.js": "^4.5.1",
    "chess.js": "^1.4.0",
    "chordsheetjs": "^15.5.1",
    "codemirror": "^6.0.2",
    "concurrently": "^10.0.3",
    "cytoscape": "^3.34.0",
    "dompurify": "^3.4.11",
    "echarts": "^6.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-is-dev": "^3.0.1",
    "jspdf": "^4.2.1",
    "jsxgraph": "^1.12.2",
    "katex": "^0.17.0",
    "lucide-react": "^1.21.0",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "mermaid": "^11.16.0",
    "node-emoji": "^2.2.0",
    "nomnoml": "^1.7.0",
    "opensheetmusicdisplay": "^2.0.0",
    "plotly.js-dist-min": "^3.6.0",
    "pseudocode": "^2.4.1",
    "qrcode": "^1.5.4",
    "railroad-diagrams": "^1.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-stringify": "^10.0.1",
    "rst2html": "^1.0.4",
    "showdown": "^2.1.0",
    "smiles-drawer": "^2.4.1",
    "tabulator-tables": "^6.5.2",
    "textile-js": "^2.1.1",
    "unified": "^11.0.5",
    "uniorg-parse": "^3.2.2",
    "uniorg-rehype": "^2.2.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "vexchords": "^1.2.0",
    "vexflow": "^5.0.0",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10",
    "wavedrom": "^3.6.1"
  },
  "build": {
    "appId": "com.yaiol.markzen.app",
    "productName": "Markzen",
    "extends": null,
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "seeds/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "fileAssociations": [
      {
        "ext": "adoc",
        "name": "AsciiDoc File",
        "description": "AsciiDoc document",
        "role": "Editor",
        "icon": "public/ext-adoc"
      },
      {
        "ext": "asciidoc",
        "name": "AsciiDoc File",
        "description": "AsciiDoc document",
        "role": "Editor",
        "icon": "public/ext-adoc"
      },
      {
        "ext": "asc",
        "name": "AsciiDoc File",
        "description": "AsciiDoc document",
        "role": "Editor",
        "icon": "public/ext-adoc"
      },
      {
        "ext": "dj",
        "name": "Djot File",
        "description": "Djot document",
        "role": "Editor",
        "icon": "public/ext-dj"
      },
      {
        "ext": "md",
        "name": "Markdown File",
        "description": "Markdown document",
        "role": "Editor",
        "icon": "public/ext-md"
      },
      {
        "ext": "markdown",
        "name": "Markdown File",
        "description": "Markdown document",
        "role": "Editor",
        "icon": "public/ext-md"
      },
      {
        "ext": "org",
        "name": "Org-Mode File",
        "description": "Org-Mode document",
        "role": "Editor",
        "icon": "public/ext-org"
      },
      {
        "ext": "rst",
        "name": "reStructuredText File",
        "description": "reStructuredText document",
        "role": "Editor",
        "icon": "public/ext-rst"
      },
      {
        "ext": "rest",
        "name": "reStructuredText File",
        "description": "reStructuredText document",
        "role": "Editor",
        "icon": "public/ext-rst"
      },
      {
        "ext": "textile",
        "name": "Textile File",
        "description": "Textile document",
        "role": "Editor",
        "icon": "public/ext-textile"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/app.ico",
      "extraResources": [
        {
          "from": "vendor/pandoc/win",
          "to": "pandoc"
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "public/app.icns",
      "extraResources": [
        {
          "from": "vendor/pandoc/mac-x64",
          "to": "pandoc"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/app.png",
      "extraResources": [
        {
          "from": "vendor/pandoc/linux",
          "to": "pandoc"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "yaiol",
      "shortcutName": "Markzen",
      "uninstallDisplayName": "yaiol Markzen"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yaiol",
        "repo": "markzen"
      }
    ]
  }
}
